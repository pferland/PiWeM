<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<title>PiWeM Space Telemetry Portal</title>
	<link rel="stylesheet" type="text/css" href="style.css">
	<style>
		@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Space+Grotesk:wght@400;600;700&display=swap');

		body {
			background: radial-gradient(circle at 50% 50%, #0d0a24 0%, #03020b 100%);
			color: #e2e8f0;
			font-family: 'Space Grotesk', sans-serif;
			margin: 0;
			padding: 0;
			min-height: 100vh;
			overflow-x: hidden;
			position: relative;
		}

		/* Animated Starfield */
		.starfield {
			position: fixed;
			top: 0; left: 0; right: 0; bottom: 0;
			pointer-events: none;
			z-index: 0;
			background-image: 
				radial-gradient(1px 1px at 20px 30px, #eee, rgba(0,0,0,0)),
				radial-gradient(2px 2px at 40px 70px, #fff, rgba(0,0,0,0)),
				radial-gradient(1.5px 1.5px at 50px 160px, #ddd, rgba(0,0,0,0)),
				radial-gradient(2px 2px at 90px 40px, #fff, rgba(0,0,0,0)),
				radial-gradient(1px 1px at 130px 80px, #fff, rgba(0,0,0,0)),
				radial-gradient(2.5px 2.5px at 160px 120px, #a78bfa, rgba(0,0,0,0));
			background-size: 240px 240px;
			opacity: 0.35;
			animation: starsMove 150s linear infinite;
		}
		@keyframes starsMove {
			from { background-position: 0 0; }
			to { background-position: 0 1000px; }
		}

		/* Nebulae blur effects */
		.nebula-cyan {
			position: fixed;
			top: -10%; left: -10%;
			width: 50vw; height: 50vw;
			background: radial-gradient(circle, rgba(0, 242, 254, 0.08) 0%, rgba(0,0,0,0) 70%);
			filter: blur(120px);
			pointer-events: none;
			z-index: 0;
		}
		.nebula-purple {
			position: fixed;
			bottom: -10%; right: -10%;
			width: 60vw; height: 60vw;
			background: radial-gradient(circle, rgba(167, 139, 250, 0.08) 0%, rgba(0,0,0,0) 70%);
			filter: blur(120px);
			pointer-events: none;
			z-index: 0;
		}

		/* Sub Header */
		.sub_header {
			background: rgba(8, 6, 22, 0.75) !important;
			border-bottom: 2px solid rgba(0, 242, 254, 0.35) !important;
			padding: 22px 30px !important;
			box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
			backdrop-filter: blur(15px);
			z-index: 2;
			position: relative;
		}
		.sub_header h2 {
			margin: 0;
			font-family: 'Orbitron', sans-serif;
			font-weight: 900;
			text-transform: uppercase;
			letter-spacing: 4px;
			background: linear-gradient(45deg, #00f2fe, #a78bfa);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			text-shadow: 0 0 25px rgba(0, 242, 254, 0.2);
		}

		/* Sidebar / Navigation Menu */
		.contents {
			background: rgba(8, 6, 22, 0.5) !important;
			border-right: 1px solid rgba(0, 242, 254, 0.15) !important;
			padding: 25px 20px !important;
			backdrop-filter: blur(12px);
			z-index: 1;
		}
		.contents ul {
			list-style: none;
			padding: 0;
			margin: 0;
		}
		.contents li a {
			display: block;
			padding: 12px 18px;
			color: #a78bfa;
			text-decoration: none;
			font-family: 'Orbitron', sans-serif;
			font-weight: 700;
			font-size: 0.85em;
			text-transform: uppercase;
			letter-spacing: 2px;
			border-radius: 8px;
			transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
			background: rgba(255, 255, 255, 0.02);
			border: 1px solid rgba(255, 255, 255, 0.04);
			margin-bottom: 12px;
		}
		.contents li a:hover {
			background: rgba(167, 139, 250, 0.15);
			color: #ffffff;
			border-color: #a78bfa;
			box-shadow: 0 0 20px rgba(167, 139, 250, 0.4);
			transform: translateX(6px);
		}

		/* Main Layout Area */
		.body {
			background: transparent !important;
			padding: 40px !important;
			z-index: 1;
			position: relative;
		}

		/* Tables / Data Cards */
		table {
			border-collapse: separate;
			border-spacing: 0 10px;
			width: 100%;
		}
		tr.station_header th {
			background: linear-gradient(135deg, rgba(8, 6, 22, 0.9) 0%, rgba(15, 10, 38, 0.85) 100%) !important;
			backdrop-filter: blur(10px);
			border: 1px solid rgba(0, 242, 254, 0.25) !important;
			border-bottom: none !important;
			border-radius: 12px 12px 0 0;
			color: #00f2fe !important;
			font-family: 'Orbitron', sans-serif;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 2px;
			padding: 16px !important;
			box-shadow: 0 4px 20px rgba(0, 242, 254, 0.08);
		}
		tr.station_header th a {
			color: #00f2fe;
			text-decoration: none;
			transition: all 0.3s ease;
		}
		tr.station_header th a:hover {
			color: #ffffff;
			text-shadow: 0 0 10px rgba(0, 242, 254, 0.8);
		}
		tr.sensor_header th {
			background: rgba(8, 6, 22, 0.7) !important;
			border-left: 1px solid rgba(0, 242, 254, 0.15) !important;
			border-right: 1px solid rgba(0, 242, 254, 0.15) !important;
			color: #c084fc !important;
			font-family: 'Orbitron', sans-serif;
			font-size: 0.85em;
			text-transform: uppercase;
			letter-spacing: 1px;
			padding: 10px !important;
		}
		tr.sensor_values td {
			background: rgba(12, 9, 30, 0.5) !important;
			border-top: 1px solid rgba(255, 255, 255, 0.02) !important;
			border-bottom: 1px solid rgba(255, 255, 255, 0.02) !important;
			backdrop-filter: blur(10px);
			color: #e2e8f0 !important;
			padding: 12px 16px !important;
		}
		tr.sensor_values td:first-child {
			border-left: 1px solid rgba(0, 242, 254, 0.15) !important;
			border-radius: 6px 0 0 6px;
			background: rgba(0, 242, 254, 0.02) !important;
		}
		tr.sensor_values td:last-child {
			border-right: 1px solid rgba(0, 242, 254, 0.15) !important;
			border-radius: 0 6px 6px 0;
			font-family: 'Orbitron', sans-serif;
			font-weight: 700;
			color: #00f2fe !important;
			text-align: center;
			text-shadow: 0 0 10px rgba(0, 242, 254, 0.6);
		}

		/* Select Dropdowns */
		select {
			background: #080616 !important;
			color: #00f2fe !important;
			border: 1px solid rgba(0, 242, 254, 0.3) !important;
			border-radius: 8px;
			padding: 8px 14px !important;
			font-family: 'Space Grotesk', sans-serif;
			font-weight: 600;
			outline: none;
			cursor: pointer;
			box-shadow: 0 0 12px rgba(0, 242, 254, 0.08);
			transition: all 0.3s ease;
		}
		select:hover, select:focus {
			border-color: #00f2fe !important;
			box-shadow: 0 0 18px rgba(0, 242, 254, 0.35) !important;
		}
		
		/* Text controls */
		label {
			font-family: 'Orbitron', sans-serif;
			font-size: 0.8em;
			letter-spacing: 1px;
			color: #a78bfa;
		}
	</style>
</head>
<body>
<!-- Backdrops -->
<div class="starfield"></div>
<div class="nebula-cyan"></div>
<div class="nebula-purple"></div>

<table style="width: 100%">
	<tr>
		<td colspan="2" align="left" class="sub_header">
			{% include 'sub_header.twig' %}
		</td>
	</tr>
	<tr>
		<td width="10%" valign="top" class="contents"><!-- Contents Index -->
			{% include 'contents.twig' %}
		</td>
		<td align="center" class="body"><!-- Body of page -->
