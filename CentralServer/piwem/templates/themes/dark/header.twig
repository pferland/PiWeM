<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<title>Raspberry Pi Weather Monitor (Dark Theme)</title>
	<link rel="stylesheet" type="text/css" href="style.css">
	<style>
		body {
			background-color: #121212;
			color: #e0e0e0;
			font-family: Arial, sans-serif;
		}
		a {
			color: #bb86fc;
		}
		table {
			border-color: #333333;
		}
		.station_header th {
			background-color: #1f1f1f !important;
			color: #ffffff !important;
		}
		.sensor_header th {
			background-color: #2c2c2c !important;
			color: #ffffff !important;
		}
		.sensor_values td {
			background-color: #1e1e1e !important;
			color: #e0e0e0 !important;
		}
		.sub_header, .contents, .body {
			background-color: #121212 !important;
			color: #e0e0e0 !important;
			border-color: #333333 !important;
		}
		select, input {
			background-color: #1e1e1e;
			color: #ffffff;
			border: 1px solid #333333;
			padding: 3px;
		}
	</style>
</head>
<body>
<table style="width: 100%">
	<tr>
		<td colspan="2" align="left" class="sub_header">
			{% include 'sub_header.twig' %}
		</td>
	</tr>
	<tr>
		<td width="10%" valign="top" class="contents"><!-- Contents Index -->
			{% include 'contents.twig' %}
		</td>
		<td align="center" class="body"><!-- Body of page -->
